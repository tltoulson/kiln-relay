# Port this server listens on.
# Use a Unifi port-forward rule to redirect kiln traffic here.
PORT=3000

# --- Local Logging ---
# Set to true to log incoming kiln requests to a local file.
LOG_ENABLED=true
# Absolute or relative path to the log file. Created if it doesn't exist.
# When running in Docker use /logs/kiln.log (maps to ./logs/ on the host via the volume mount).
LOG_FILE=/logs/kiln.log

# --- Forwarding ---
# Set to true to forward incoming kiln requests to FORWARD_URL.
FORWARD_ENABLED=true
# Full base URL to forward to (e.g. https://myapp.example.com).
# The original request path is appended automatically.
FORWARD_URL=https://your-app.example.com
# Basic auth credentials for the forwarding request. Leave blank if not needed.
FORWARD_USERNAME=
FORWARD_PASSWORD=
